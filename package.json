{
  "name": "react-native-chess-kit",
  "version": "0.5.3",
  "description": "High-performance chess board for React Native. Single gesture handler, ~40 components, 0 re-renders during drag. Built on Reanimated + Gesture Handler.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf lib",
    "prepare": "husky",
    "prepack": "bob build"
  },
  "keywords": [
    "react-native",
    "chess",
    "chessboard",
    "chess-board",
    "reanimated",
    "gesture-handler",
    "performance",
    "60fps"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anas-asghar4831/react-native-chess-kit"
  },
  "homepage": "https://github.com/anas-asghar4831/react-native-chess-kit#readme",
  "bugs": {
    "url": "https://github.com/anas-asghar4831/react-native-chess-kit/issues"
  },
  "author": "anas-asghar4831",
  "license": "MIT",
  "peerDependencies": {
    "chess.js": ">=1.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "chess.js": "^1.4.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.35.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "~15.11.2",
    "typescript": "~5.9.2",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "rimraf": "^6.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
